{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rooseveltops.nl/schemas/agent-hq/agent-message-v1.json",
  "title": "Agent HQ Message Schema",
  "description": "Standardized inter-agent communication protocol for the Agent HQ multi-agent system. All messages between orchestrator, managers, and specialist workers follow this schema.",
  "version": "1.0.0",
  "type": "object",
  "required": ["message_id", "timestamp", "from", "to", "type", "payload", "context"],
  "additionalProperties": false,

  "properties": {
    "message_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this message (UUID v4)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when message was created"
    },
    "from": {
      "$ref": "#/definitions/agentRef",
      "description": "Sending agent identity"
    },
    "to": {
      "$ref": "#/definitions/agentRef",
      "description": "Receiving agent identity"
    },
    "type": {
      "type": "string",
      "enum": [
        "task_assignment",
        "task_result",
        "status_update",
        "escalation",
        "quality_gate",
        "context_share",
        "heartbeat"
      ],
      "description": "Message type determining payload structure"
    },
    "payload": {
      "type": "object",
      "description": "Message-type-specific data. Schema varies by message type.",
      "oneOf": [
        { "$ref": "#/definitions/taskAssignmentPayload" },
        { "$ref": "#/definitions/taskResultPayload" },
        { "$ref": "#/definitions/statusUpdatePayload" },
        { "$ref": "#/definitions/escalationPayload" },
        { "$ref": "#/definitions/qualityGatePayload" },
        { "$ref": "#/definitions/contextSharePayload" },
        { "$ref": "#/definitions/heartbeatPayload" }
      ]
    },
    "context": {
      "$ref": "#/definitions/messageContext",
      "description": "Tracing and session context for this message"
    },
    "metadata": {
      "$ref": "#/definitions/messageMetadata",
      "description": "Optional operational metadata (priority, timeouts, retries)"
    }
  },

  "definitions": {
    "agentRef": {
      "type": "object",
      "required": ["agent_id", "agent_type"],
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "maxLength": 64,
          "description": "Unique agent instance identifier"
        },
        "agent_type": {
          "type": "string",
          "enum": ["orchestrator", "manager", "specialist"],
          "description": "Agent tier in the hierarchy"
        },
        "agent_role": {
          "type": "string",
          "enum": [
            "orchestrator",
            "planning-manager",
            "execution-manager",
            "quality-manager",
            "research",
            "planning",
            "coding",
            "testing",
            "review"
          ],
          "description": "Specific role within the agent type"
        }
      }
    },

    "taskAssignmentPayload": {
      "type": "object",
      "required": ["task_id", "objective", "acceptance_criteria"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "CLEO task ID or generated subtask ID"
        },
        "objective": {
          "type": "string",
          "maxLength": 500,
          "description": "Clear description of what needs to be accomplished"
        },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Specific criteria that must be met for task completion"
        },
        "context_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File paths relevant to this task"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Task IDs that must complete before this task"
        },
        "constraints": {
          "type": "object",
          "properties": {
            "max_files_changed": { "type": "integer", "minimum": 1 },
            "max_lines_changed": { "type": "integer", "minimum": 1 },
            "scope_boundary": { "type": "string" },
            "technology_constraints": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "description": "Boundaries and constraints for this task"
        }
      }
    },

    "taskResultPayload": {
      "type": "object",
      "required": ["task_id", "status", "summary"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Task ID being reported on"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed", "partial", "blocked"],
          "description": "Outcome of the task"
        },
        "summary": {
          "type": "string",
          "maxLength": 1000,
          "description": "Human-readable summary of what was accomplished"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "path"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["file_change", "test_result", "report", "review"]
              },
              "path": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Artifacts produced by this task"
        },
        "metrics": {
          "type": "object",
          "properties": {
            "duration_ms": { "type": "integer", "minimum": 0 },
            "tokens_used": { "type": "integer", "minimum": 0 },
            "files_changed": { "type": "integer", "minimum": 0 },
            "lines_added": { "type": "integer", "minimum": 0 },
            "lines_removed": { "type": "integer", "minimum": 0 }
          },
          "description": "Execution metrics"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "recoverable": { "type": "boolean" }
            }
          },
          "description": "Errors encountered during execution"
        }
      }
    },

    "statusUpdatePayload": {
      "type": "object",
      "required": ["task_id", "progress"],
      "properties": {
        "task_id": { "type": "string" },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Completion percentage"
        },
        "current_step": { "type": "string" },
        "estimated_remaining_ms": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string", "maxLength": 500 }
      }
    },

    "escalationPayload": {
      "type": "object",
      "required": ["task_id", "reason", "severity"],
      "properties": {
        "task_id": { "type": "string" },
        "reason": { "type": "string", "maxLength": 500 },
        "severity": {
          "type": "string",
          "enum": ["blocker", "critical", "major", "minor"]
        },
        "attempted_actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Actions already attempted to resolve"
        },
        "suggested_resolution": {
          "type": "string",
          "description": "Agent's suggested next step"
        }
      }
    },

    "qualityGatePayload": {
      "type": "object",
      "required": ["task_id", "gate_type", "verdict"],
      "properties": {
        "task_id": { "type": "string" },
        "gate_type": {
          "type": "string",
          "enum": ["code_review", "test_quality", "integration", "final_review"]
        },
        "verdict": {
          "type": "string",
          "enum": ["pass", "fail", "conditional_pass"]
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["severity", "description"],
            "properties": {
              "severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low", "info"]
              },
              "description": { "type": "string" },
              "file": { "type": "string" },
              "line": { "type": "integer" },
              "suggestion": { "type": "string" }
            }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "coverage_percent": { "type": "number", "minimum": 0, "maximum": 100 },
            "critical_issues": { "type": "integer", "minimum": 0 },
            "high_issues": { "type": "integer", "minimum": 0 },
            "medium_issues": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },

    "contextSharePayload": {
      "type": "object",
      "required": ["knowledge_type", "content"],
      "properties": {
        "knowledge_type": {
          "type": "string",
          "enum": ["discovery", "decision", "dependency", "risk", "pattern"]
        },
        "content": { "type": "string", "maxLength": 2000 },
        "related_entities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence level of this knowledge (0.0-1.0)"
        }
      }
    },

    "heartbeatPayload": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["alive", "busy", "idle", "shutting_down"]
        },
        "current_task_id": { "type": "string" },
        "uptime_ms": { "type": "integer", "minimum": 0 },
        "token_budget_remaining": { "type": "integer", "minimum": 0 }
      }
    },

    "messageContext": {
      "type": "object",
      "required": ["session_id", "trace_id"],
      "properties": {
        "session_id": {
          "type": "string",
          "description": "CLEO session or orchestration session ID"
        },
        "parent_task_id": {
          "type": "string",
          "description": "Parent task that spawned this message chain"
        },
        "trace_id": {
          "type": "string",
          "format": "uuid",
          "description": "End-to-end trace ID for observability"
        },
        "span_id": {
          "type": "string",
          "description": "Span ID within the trace"
        },
        "cleo_task_id": {
          "type": "string",
          "pattern": "^T\\d+$",
          "description": "CLEO task reference (e.g., T001)"
        },
        "plane_issue_id": {
          "type": "string",
          "description": "Plane issue UUID if linked"
        }
      }
    },

    "messageMetadata": {
      "type": "object",
      "properties": {
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "default": "medium"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 600000,
          "default": 300000,
          "description": "Maximum time to wait for response (ms)"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "default": 3
        },
        "token_budget": {
          "type": "integer",
          "minimum": 1000,
          "description": "Maximum tokens this agent may use"
        },
        "idempotency_key": {
          "type": "string",
          "description": "Key for deduplication of retry messages"
        }
      }
    }
  }
}
