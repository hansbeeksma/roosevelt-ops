# Metabase Configuration
# Copy to .env and fill in actual values:
#   cp .env.example .env && chmod 600 .env

# --- Domain (for Caddy automatic HTTPS) ---
DOMAIN=metabase.rooseveltops.nl

# --- Database Connection (Supabase PostgreSQL) ---
MB_DB_TYPE=postgres
MB_DB_DBNAME=postgres
MB_DB_PORT=5432
MB_DB_USER=postgres
MB_DB_HOST=db.xxxxxxxxxxx.supabase.co
MB_DB_CONNECTION_URI=postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxx.supabase.co:5432/postgres?sslmode=verify-full

# --- Security ---
MB_PASSWORD_COMPLEXITY=strong
MB_PASSWORD_LENGTH=10

# --- Performance ---
JAVA_OPTS=-Xmx2g -Xms1g
MB_APPLICATION_DB_MAX_CONNECTION_POOL_SIZE=15

# --- Optional: SMTP for email alerts ---
# MB_EMAIL_SMTP_HOST=smtp.example.com
# MB_EMAIL_SMTP_PORT=587
# MB_EMAIL_SMTP_USERNAME=metabase@rooseveltops.nl
# MB_EMAIL_SMTP_PASSWORD=
# MB_EMAIL_FROM_ADDRESS=metabase@rooseveltops.nl
# MB_EMAIL_FROM_NAME=Roosevelt Metrics
